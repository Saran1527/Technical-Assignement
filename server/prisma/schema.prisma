generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PROJECT_MANAGER
  DEVELOPER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  OVERDUE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  role          UserRole
  refreshToken  String?
  projects      Project[]      @relation("ProjectManager")
  tasks         Task[]         @relation("AssignedDeveloper")
  activities    ActivityLog[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([email])
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  clientId    String?
  managerId   String
  manager     User          @relation("ProjectManager", fields: [managerId], references: [id])
  tasks       Task[]
  activities  ActivityLog[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([managerId])
}

model Task {
  id              String        @id @default(uuid())
  title           String
  description     String?
  status          TaskStatus    @default(TODO)
  priority        TaskPriority  @default(MEDIUM)
  dueDate         DateTime
  projectId       String
  project         Project       @relation(fields: [projectId], references: [id])
  developerId     String
  developer       User          @relation("AssignedDeveloper", fields: [developerId], references: [id])
  activities      ActivityLog[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([projectId])
  @@index([developerId])
  @@index([status])
  @@index([dueDate])
}

model ActivityLog {
  id        String   @id @default(uuid())
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id])
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // e.g., "moved Task #1 from In Progress -> In Review"
  timestamp DateTime @default(now())

  @@index([projectId])
  @@index([taskId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}
